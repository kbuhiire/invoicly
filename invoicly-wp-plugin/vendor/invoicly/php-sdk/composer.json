{
    "name": "invoicly/php-sdk",
    "description": "PHP SDK for the Invoicly API — generate and download invoices from any PHP application.",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Invoicly\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Invoicly\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
