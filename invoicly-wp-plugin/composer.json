{
    "name": "invoicly/wp-plugin",
    "description": "WordPress plugin for Invoicly — generate and download invoices via the Invoicly PHP SDK.",
    "type": "wordpress-plugin",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "invoicly/php-sdk": "^1.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../packages/invoicly-php-sdk",
            "options": {
                "symlink": false
            }
        }
    ],
    "config": {
        "optimize-autoloader": true
    },
    "minimum-stability": "stable"
}
